{
  "name": "openclaw-kbprep",
  "version": "0.5.0",
  "description": "KBPrep source-to-clean-Markdown toolkit with a Python core, standalone CLI, and OpenClaw adapter.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "kbprep-preflight": "./dist/adapters/standalone/bin/preflight.js",
    "kbprep-analyze": "./dist/adapters/standalone/bin/analyze.js",
    "kbprep-prepare": "./dist/adapters/standalone/bin/prepare.js",
    "kbprep-apply-review": "./dist/adapters/standalone/bin/apply-review.js",
    "kbprep-cleanup": "./dist/adapters/standalone/bin/cleanup.js",
    "kbprep-batch": "./dist/adapters/standalone/bin/batch.js"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "docs:serve": "node scripts/serve-docs.mjs",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.js",
    "plugin:validate": "npm run build && openclaw plugins validate --entry ./dist/index.js",
    "pack:check": "node scripts/check-pack.mjs",
    "test": "vitest run --pool=forks --maxWorkers=1 --testTimeout=30000"
  },
  "files": [
    "dist",
    "python/kbprep_worker/**/*.py",
    "python/pyproject.toml",
    "skills",
    "docs",
    "CHANGELOG.md",
    "LICENSE",
    "openclaw.plugin.json",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "openclaw": "2026.5.27",
    "typescript": "^5.9.0",
    "vitest": "^4.1.8"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
