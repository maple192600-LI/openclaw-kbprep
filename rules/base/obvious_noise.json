{
  "schema": "kbprep.cleaning_rules.v1",
  "description": "Generic cleanup signals that are not tied to one publishing platform.",
  "rules": [
    {
      "id": "base.promotional_line.companion_video",
      "type": "promotional_line",
      "action": "discard",
      "match": "regex",
      "pattern": "配套视频教程[:：].*",
      "risk_tag": "promotional_line",
      "reason": "standalone companion-video/update packaging line"
    },
    {
      "id": "base.promotional_line.future_updates",
      "type": "promotional_line",
      "action": "discard",
      "match": "regex",
      "pattern": "后续更新[:：].*",
      "risk_tag": "promotional_line",
      "reason": "standalone update-channel packaging line"
    },
    {
      "id": "base.promotional_line.english_qr_claim",
      "type": "promotional_line",
      "action": "discard",
      "match": "regex",
      "pattern": "scan the qr code.*(?:join|claim|free)",
      "risk_tag": "promotional_line",
      "reason": "standalone QR claim call"
    },
    {
      "id": "base.promotional_line.english_signup",
      "type": "promotional_line",
      "action": "discard",
      "match": "regex",
      "pattern": "(?:sign up for free|click here to claim|claim your free)",
      "risk_tag": "promotional_line",
      "reason": "standalone signup or claim call"
    }
  ],
