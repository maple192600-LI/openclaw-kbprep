{
  "schema": "kbprep.cleaning_rules.v1",
  "description": "Optional self-media/course cleanup template. This is not loaded by the generic standard profile.",
  "rules": [
    {
      "id": "self_media.promotional_line.follow_platform",
      "type": "promotional_line",
      "action": "discard",
      "match": "regex",
      "pattern": "(?:欢迎)?关注(?:公众号|视频号|小红书|B站|抖音|YouTube|频道|账号)",
      "risk_tag": "promotional_line",
      "reason": "standalone platform follow line"
    },
    {
      "id": "self_media.promotional_line.subscribe_platform",
      "type": "promotional_line",
      "action": "discard",
      "match": "regex",
      "pattern": "(?:关注|订阅).{0,8}(?:公众号|视频号|小红书|B站|抖音|YouTube|频道|账号)",
      "risk_tag": "promotional_line",
      "reason": "standalone platform subscription line"
    },
    {
      "id": "self_media.promotional_line.english_follow",
      "type": "promotional_line",
      "action": "discard",
      "match": "regex",
      "pattern": "(?:follow us on|subscribe to|subscribe to our)",
      "risk_tag": "promotional_line",
      "reason": "standalone social follow line"
    }
  ],
  "keyword_sets": {
